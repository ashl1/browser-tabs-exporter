{
  "manifest_version": 3,
  "name": "Tabs Exporter",
  "version": "1.3.1",
  "description": "Export every open tab (windows, tab groups, incognito) to structured Markdown — locally or straight to Google Drive.",
  "minimum_chrome_version": "116",
  "incognito": "spanning",
  "permissions": [
    "tabs",
    "tabGroups",
    "downloads",
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://ashl1.github.io/browser-tabs-exporter/picker.html"],
      "js": ["content/picker-relay.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Tabs Exporter — export tabs to Markdown",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "oauth2": {
    "client_id": "567268955685-4a7en406sajuoa6fmvacr5igdu34lmc3.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  }
}

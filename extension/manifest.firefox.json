{
  "manifest_version": 3,
  "name": "Tabs Exporter",
  "version": "1.2.0",
  "description": "Export every open tab (windows, tab groups, private) to structured Markdown — locally or straight to Google Drive.",
  "incognito": "spanning",
  "permissions": [
    "tabs",
    "tabGroups",
    "downloads",
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://your-github-username.github.io/save_tabs_extension/*"],
      "js": ["content/picker-relay.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Tabs Exporter — export tabs to Markdown",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabs-exporter@example.com",
      "strict_min_version": "139.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
